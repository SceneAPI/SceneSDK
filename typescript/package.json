{
  "name": "@sfmapi/client",
  "version": "0.0.1",
  "description": "Typed TypeScript SDK for sfmapi (browser + Node).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generated": {
      "types": "./dist/_generated/client.d.ts",
      "import": "./dist/_generated/client.js",
      "require": "./dist/_generated/client.cjs"
    },
    "./generated/openapi": {
      "types": "./dist/_generated/openapi.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/_generated/client.ts --format esm,cjs --dts --sourcemap --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:openapi-types": "openapi-typescript ../openapi.json -o src/openapi-types.ts",
    "gen:sdk": "openapi-typescript ../openapi.json -o src/_generated/openapi.d.ts",
    "check:openapi-drift": "tsc --noEmit --project tsconfig.drift.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.6.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SFMAPI/sfmapi-sdk.git",
    "directory": "typescript"
  },
  "keywords": [
    "sfmapi",
    "structure-from-motion",
    "colmap",
    "sdk"
  ],
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
